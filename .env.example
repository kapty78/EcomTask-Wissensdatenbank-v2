# =====================================================================
# Server-Env-Schema (validiert in lib/env.ts, WP-A5 Feature 007)
# Pflicht-Variablen ohne Default lassen Build/Boot benennend scheitern.
# Keine echten Werte hier eintragen — nur Platzhalter.
# =====================================================================

# — Knowledge-Retrieval (Support-Backend /api/knowledge/retrieve) —
# Optional, Default: https://outlook-ai-frontend-v3-2s1l.onrender.com/api/knowledge/retrieve
# KNOWLEDGE_API_URL=
# Pflicht (min. 16 Zeichen)
KNOWLEDGE_API_KEY=CHANGE_ME_MIN_16_CHARS

# — Support-Backend (Skills-Proxy, Graph-Extraction) —
# Pflicht (URL)
SUPPORT_BACKEND_URL=https://example.onrender.com
# Pflicht (min. 16 Zeichen)
SUPPORT_BACKEND_API_KEY=CHANGE_ME_MIN_16_CHARS

# — Cross-Agent-Auth (Service-zu-Service) —
# Pflicht (min. 32 Zeichen)
CROSS_AGENT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_HEX

# — Wissensbasis-Pipeline (PDF-Generierung) —
# Optional, Default: https://wissensbasis-pipeline.onrender.com
# WISSENSBASIS_PIPELINE_URL=
# Pflicht (min. 8 Zeichen)
WISSENSBASIS_API_KEY=CHANGE_ME

# — Kern-Secrets —
# Pflicht (min. 20 Zeichen)
OPENAI_API_KEY=sk-CHANGE_ME
# Pflicht (min. 20 Zeichen)
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# — Modell-Auswahl —
# Optional, Default: gpt-5.5-2026-04-23 (Legacy-Fallback: OPENAI_MODEL)
# KNOWLEDGE_AGENT_MODEL=
