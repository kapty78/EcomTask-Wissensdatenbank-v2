        "parameters": {
          "jsCode": "// Embeddings den 5 Fragen zuordnen und Such-JSON erzeugen\nconst questions = $('Aggregate Questions').first().json.questions;\nconst embeddings = $json.data.map(d => d.embedding);\n\nreturn questions.map((q, i) => ({\n  json: {\n    question: q,\n    query_embedding: embeddings[i],\n    kb_id: \"600f01cc-53fb-4f09-8ba6-3f52fdd95097\",\n    match_count: 10,\n    similarity_threshold: 0.45\n  }\n}));"
