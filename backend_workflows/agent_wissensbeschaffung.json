        "parameters": {
          "jsCode": "// 1) Array aus der GPT-Antwort holen (richtiger Key: 'queries')\nconst qs = items[0].json.choices[0].message.content.queries ?? [];\n\n// 2) Für jede Frage ein neues Item erzeugen\nreturn qs.map(q => ({\n  json: { question: q }\n}));"
