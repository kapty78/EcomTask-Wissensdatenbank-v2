      {
        "parameters": {
          "jsCode": "// Deduplizierung nach ID, Sortierung nach similarity, Top-20\nconst allItems = $input.all().map(i => i.json);\n\nconst seen = new Map();\nfor (const item of allItems) {\n  const id = item.ki_id ?? item.id ?? item.content;\n  if (!seen.has(id) || (item.similarity ?? 0) > (seen.get(id).similarity ?? 0)) {\n    seen.set(id, item);\n  }\n}\n\nconst deduped = [...seen.values()]\n  .sort((a, b) => (b.similarity ?? 0) - (a.similarity ?? 0))\n  .slice(0, 20);\n\nreturn deduped.map(item => ({ json: item }));"
        },
