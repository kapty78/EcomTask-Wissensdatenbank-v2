"use client"

import React, { useState, useEffect, useCallback, useRef } from 'react'
import { createClientComponentClient } from '@supabase/auth-helpers-nextjs'
import { Button } from '@/components/ui/button'
import { Separator } from '@/components/ui/separator'
import { Search, Loader2, FileText } from 'lucide-react'

interface SearchResult {
  id: string
  pagecontent: string
  metadata: {
    chunk_id: string
    fact_type: string
    document_id: string
    knowledge_base_id: string
  }
  similarity: number
  title?: string
  facts?: any[]
}

interface ChatInterfaceProps {
  knowledgeBaseId: string
  height?: string
  onOpenChunkDetails: (item: { id: string; source_chunk: string; document_id: string }) => void
}

export default function ChatInterface({ knowledgeBaseId, height = "600px", onOpenChunkDetails }: ChatInterfaceProps) {
  const supabase = createClientComponentClient()
  const [searchQuery, setSearchQuery] = useState('')
  const [searchResults, setSearchResults] = useState<SearchResult[]>([])
  const [isLoading, setIsLoading] = useState(false)
  const [userId, setUserId] = useState<string | null>(null)
  const [showSearchField, setShowSearchField] = useState(true)
  const [lastSearchQuery, setLastSearchQuery] = useState('')
  const searchInputRef = useRef<HTMLTextAreaElement>(null)

  // Hole die User-ID beim Mount
  useEffect(() => {
    const getUser = async () => {
      const { data: { user } } = await supabase.auth.getUser()
      if (user) {
        setUserId(user.id)
      }
    }
    getUser()
  }, [supabase.auth])

  // Suche nach ähnlichen Chunks
  const searchChunks = useCallback(async () => {
    if (!searchQuery.trim() || !userId || isLoading) return

    setIsLoading(true)
    setSearchResults([])
    setLastSearchQuery(searchQuery)
    setShowSearchField(false)

    try {
      const response = await fetch('https://automation.ecomtask.de/webhook/wdb-chat/v1', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          message: searchQuery,
          knowledgeBaseId,
          userId
        })
      })

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`)
      }

      const data = await response.json()

      console.log('Webhook-Antwort:', data)

      let rawSearchResults: SearchResult[] = []

      if (data && typeof data === 'object' && 'data' in data && Array.isArray(data.data)) {
        rawSearchResults = data.data as SearchResult[]
      } else if (Array.isArray(data) && data.length > 0 && typeof data[0] === 'object' && 'pagecontent' in data[0]) {
        rawSearchResults = data as SearchResult[]
      }

      console.log('Verarbeitete Rohdaten von Webhook:', rawSearchResults)

      if (rawSearchResults.length > 0) {
        const resultsWithDetails = await Promise.all(
          rawSearchResults.map(async (result) => {
            try {
              const { data: chunkData, error: chunkError } = await supabase
                .from('chunks')
                .select(`
                  metadata,
                  knowledge_items!inner(title)
                `)
                .eq('id', result.metadata.chunk_id)
                .eq('knowledge_items.knowledge_base_id', knowledgeBaseId)
                .single()

              if (chunkError || !chunkData) {
                return { ...result, title: `Unbenannt (${result.metadata.fact_type})`, facts: [] }
              }

              return {
                ...result,
                title: chunkData.knowledge_items?.[0]?.title || `Unbenannt (${result.metadata.fact_type})`,
                facts: chunkData.metadata?.facts || []
              }
            } catch (dbError) {
              return { ...result, title: `Fehler (${result.metadata.fact_type})`, facts: [] }
            }
          })
        )
        setSearchResults(resultsWithDetails)
      } else {
        setSearchResults([])
      }
    } catch (error) {
      console.error('Fehler bei der Suche:', error)
      setSearchResults([])
    } finally {
      setIsLoading(false)
    }
  }, [searchQuery, knowledgeBaseId, userId, isLoading, supabase])

  // Suche bei Enter (am Ende der Eingabe)
  const handleKeyPress = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault()
      searchChunks()
    }
  }

  // Navigation zu Chunk/Fakten-Modul
  const navigateToChunk = useCallback(async (chunkId: string, documentId: string) => {
    onOpenChunkDetails({
      id: chunkId,
      source_chunk: chunkId,
      document_id: documentId,
    })
  }, [onOpenChunkDetails])

  // Suchfeld wieder öffnen
  const openSearchField = useCallback(() => {
    setShowSearchField(true)
  }, [])


  return (
    <div className="w-full h-full flex flex-col">
      {/* Header - nur wenn keine Suche aktiv */}
      {!lastSearchQuery.trim() && (
        <div className="p-4">
          {/* Beschreibung */}
          <div className="mb-3">
            <p className="text-xs text-gray-400">
              Testen Sie hier, ob Ihr Wissensdatenbank auf Kundenanfragen korrekt antwortet
            </p>
            <p className="text-xs text-gray-500 mt-1">
              Enter für neue Zeile • Enter am Ende für Suche starten
            </p>
          </div>
        </div>
      )}

      {/* Suchfeld oder kompakter Preview */}
      {showSearchField ? (
          <div className="mb-2 px-4">
            <div className="relative">
              <textarea
                ref={searchInputRef}
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                onKeyDown={handleKeyPress}
                onBlur={() => {
                  if (lastSearchQuery.trim()) {
                    setShowSearchField(false)
                  }
                }}
                disabled={isLoading || !userId}
                placeholder="Kundenmail oder Anfrage eingeben..."
                className="w-full rounded-lg border border-[#333333] bg-[#1e1e1e] py-2.5 sm:py-2 pl-3 pr-3 text-sm text-white placeholder:text-gray-500 focus:border-white/20 focus:outline-none resize-none min-h-[80px]"
                autoComplete="off"
                rows={3}
              />
            </div>
          </div>
        ) : (
          <div className="mb-2 px-4">
            <div
              className="p-2 rounded-lg border border-[#333333] bg-[#1e1e1e] cursor-pointer hover:bg-[#2a2a2a] transition-colors"
              onClick={openSearchField}
              title="Klicken zum Bearbeiten"
            >
              <div className="flex items-center justify-between">
                <div className="flex-1 min-w-0">
                  <div className="text-xs text-gray-400 mb-0.5">Aktuelle Anfrage:</div>
                  <div className="text-xs text-white line-clamp-1 truncate">
                    {lastSearchQuery}
                  </div>
                </div>
                <div className="ml-2 text-gray-500">
                  <svg className="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        )}

        {!userId && (
          <div className="text-xs text-destructive mt-1">
            Bitte melden Sie sich an, um zu suchen
          </div>
        )}

      <Separator />

      {/* Ergebnisse */}
      <div className="flex-1 overflow-y-auto px-4 py-4 max-h-[calc(100vh-400px)]">
        <div className="space-y-2">
          {isLoading ? (
            <div className="flex items-center justify-center h-32">
              <div className="text-center">
                <Loader2 className="h-8 w-8 animate-spin mx-auto mb-2" />
                <p className="text-sm text-muted-foreground">Suche läuft...</p>
              </div>
            </div>
          ) : searchResults.length === 0 ? (
            <div className="flex items-center justify-center h-32">
              <div className="text-center">
                <Search className="size-6 mx-auto mb-2 text-gray-500" />
                <p className="text-xs text-gray-500">
                  {searchQuery.trim() ? 'Keine passenden Einträge gefunden' : 'Wissenssuche - Test-Tool'}
                </p>
              </div>
            </div>
          ) : (
            <>
              {searchResults.map((result) => {
                const isQuestion = result.pagecontent.includes('?')
                const previewText = result.pagecontent.length > 150
                  ? result.pagecontent.substring(0, 150) + '...'
                  : result.pagecontent

                return (
                  <div
                    key={result.id}
                    className="mb-2 ml-1 rounded-lg border border-[#333333] bg-[#242424] p-2 sm:p-3 transition-all duration-300 ease-in-out hover:border-pink-500/30 hover:bg-[#2a2a2a] hover:transform hover:scale-[1.005] cursor-pointer"
                    onClick={() => navigateToChunk(result.metadata.chunk_id, result.metadata.document_id)}
                  >
                    <div className="flex gap-1.5">
                      <div className="flex-1 flex flex-col gap-1.5">
                        {/* Typ-Badge */}
                        <div className="text-[10px] uppercase tracking-wide inline-flex w-fit items-center rounded px-1.5 py-0.5 bg-pink-500/15 text-pink-400 border border-pink-500/30">
                          {result.metadata.fact_type}
                        </div>

                        {/* Titel - nur anzeigen wenn vorhanden */}
                        {result.title && result.title !== `Unbenannt (${result.metadata.fact_type})` && (
                          <div className="text-xs sm:text-sm font-medium text-white">
                            {result.title}
                          </div>
                        )}

                        {/* Chunk ID */}
                        <p className="text-xs text-gray-400">
                          Chunk ID: {result.metadata.chunk_id.substring(0, 8)}...
                        </p>

                        {isQuestion && (
                          <p className="text-[11px] sm:text-xs text-gray-400 mt-2 line-clamp-2">
                            Frage
                          </p>
                        )}

                        <p className="text-xs sm:text-sm text-white line-clamp-3">
                          {previewText}
                        </p>

                        <div className="flex flex-col sm:flex-row sm:justify-between gap-1">
                          <div className="flex flex-wrap gap-1 text-xs text-gray-400">
                            <span>Quelle: {result.metadata.document_id.substring(0, 20)}...</span>
                            <span>•</span>
                            <span>Erstellt: {new Date().toLocaleDateString('de-DE')}</span>
                          </div>
                          <div className="flex gap-1 flex-shrink-0">
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={(e) => {
                                e.stopPropagation()
                                navigateToChunk(result.metadata.chunk_id, result.metadata.document_id)
                              }}
                              className="text-gray-400 hover:text-white transition-colors duration-200 p-1"
                            >
                              <FileText className="size-3 sm:size-4" />
                            </Button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                )
              })}
            </>
        </div>
      </div>
    </div>
  )
}
